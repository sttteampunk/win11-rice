{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.json",
  "app_specific_configuration_path": "C:\\Users\\Lenovo\\applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "transparency": true,
  "transparency_alpha": 240,
  "default_workspace_padding": -1,
  "default_container_padding": -1,
  "border": false,
  "border_width": 0,
  "border_offset": -1,
  "border_style": "Square",
  "mouse_follows_focus": true,
  "animation": {
    "enabled": true,
    "duration": 100,
    "fps": 120,
    "style": {
        "movement":"EaseInOutQuad",
        "transparency": "Linear"
      }
},
  "border_colours": {
    "single": "#D6D8DB",
    "unfocused": "#313131",
    "floating": "#D6D8DB",
    "monocle": "#D6D8DB"
  },
  "monitors": [
    {
      "workspaces": [
