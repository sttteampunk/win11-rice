# -----------------------------------------------
# Backups created by setup.ps1
# -----------------------------------------------
*.backup_*

# -----------------------------------------------
# Windows system files
# -----------------------------------------------
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------
# Sensitive / personal files — never commit these
# -----------------------------------------------
*.env
*.secret
*_secret.*
secrets/
credentials/

# -----------------------------------------------
# Neovim
# -----------------------------------------------
nvim/.netrwhist
nvim/plugin/packer_compiled.lua
nvim/lazy-lock.json

# -----------------------------------------------
# Spicetify — generated/cache files
# -----------------------------------------------
spicetify/Backup/
spicetify/.cache/

# -----------------------------------------------
# Yazi — cache
# -----------------------------------------------
yazi/cache/

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/

# -----------------------------------------------
# OS-generated
# -----------------------------------------------
.DS_Store
